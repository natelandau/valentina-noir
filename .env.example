# =============================================================================
# Valentina Noir: Environment Configuration
# =============================================================================
#
# Copy this file to `.env.secret` and fill in the values, or set them directly
# in the environment.
#
# Conventions used in this file:
#   - Uncommented variables are REQUIRED. The application will not start
#     without them.
#   - Commented variables (prefixed with `#`) are OPTIONAL. The value shown is
#     the default; uncomment a line to override it.
#
# Generating encryption keys:
#   Two variables need a 32-byte hex key (VAPI_AUTHENTICATION_ENCRYPTION_KEY
#   and VAPI_RATE_LIMIT__ENCRYPTION_KEY). Generate each with:
#       python3 -c 'import secrets; print(secrets.token_hex(32))'
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Display name for the application. Also used to namespace all cache keys.
# (required)
VAPI_NAME=

# Run the application in debug mode.
# VAPI_DEBUG=false


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Minimum log level for application logs.
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# VAPI_LOG__LEVEL=INFO

# Path to write logs to disk. Leave empty to log only to the console.
# VAPI_LOG__FILE_PATH=

# Emit console logs as JSON instead of human-readable text.
# VAPI_LOG__JSON_CONSOLE=false

# Log level for the ASGI server.
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# VAPI_LOG__ASGI_SERVER_LEVEL=INFO

# Log level for the SAQ background worker.
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# VAPI_LOG__SAQ_LEVEL=INFO

# Log level for the root logger (third-party libraries).
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# VAPI_LOG__ROOT_LEVEL=INFO

# Fields to include in the single combined log entry written per request.
# The entry's level follows the response status: INFO for <400 and routine
# 4xx, WARNING for 401/403/429, ERROR for 5xx.
#
# Available fields:
#   path, method, query, path_params, client, content_type, scheme, cookies,
#   status_code, request_body, response_body, request_headers,
#   response_headers, duration_ms, request_id, developer_id, operation_id,
#   idempotency_key, acting_user_id, error_type, error_detail,
#   invalid_parameters
#
# Notes:
#   - request_headers logs the raw Cookie header unless 'Cookie' is added to
#     VAPI_LOG__OBFUSCATE_HEADERS below.
#   - response_body is omitted for gzip-compressed responses (size >= the
#     compression minimum); only small, uncompressed bodies are logged.
#   - These fields are conditional: developer_id (authenticated routes only),
#     operation_id (only when the handler sets one), idempotency_key (only when
#     the request sends that header), acting_user_id (only on endpoints that
#     resolve the On-Behalf-Of header), and error_type / error_detail /
#     invalid_parameters (only on requests that returned a handled error, with
#     invalid_parameters limited to validation errors).
# VAPI_LOG__LOG_FIELDS='["path","method","query","path_params","client","status_code","duration_ms","request_id","developer_id","error_type","error_detail","invalid_parameters"]'

# Response headers to obfuscate in the logs.
# VAPI_LOG__OBFUSCATE_HEADERS='["Authorization","X-API-KEY","X-CSRF-TOKEN"]'

# Cookies to obfuscate in the logs.
# VAPI_LOG__OBFUSCATE_COOKIES='["session","XSRF-TOKEN"]'

# When to log tracebacks for uncaught exceptions.
# One of: always, debug, never. With 'always' (the default), unhandled errors
# log at ERROR with a traceback in every environment. Handled client errors
# (4xx) are suppressed here since they already appear in the combined request
# entry.
# VAPI_LOG__LOG_EXCEPTIONS=always

# Include the timestamp in console logs.
# VAPI_LOG__TIME_IN_CONSOLE=true


# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# 32-byte hex key used to encrypt authentication data. See "Generating
# encryption keys" at the top of this file. (required)
VAPI_AUTHENTICATION_ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Database host.
# VAPI_POSTGRES__HOST=localhost

# Database port.
# VAPI_POSTGRES__PORT=5432

# Database user.
# VAPI_POSTGRES__USER=valentina

# Database password.
# VAPI_POSTGRES__PASSWORD=valentina

# Database name.
# VAPI_POSTGRES__DATABASE=valentina-noir


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Redis connection URL.
# VAPI_REDIS__URL=redis://localhost:6379/0

# Connection timeout in seconds.
# VAPI_REDIS__TIMEOUT=5

# Health check interval in seconds.
# VAPI_REDIS__HEALTH_CHECK_INTERVAL=5

# Keep the Redis connection alive between requests.
# VAPI_REDIS__KEEPALIVE=true


# -----------------------------------------------------------------------------
# Data Stores
# -----------------------------------------------------------------------------
# Stores are backed by Redis. All cache keys are prefixed with a slugified
# version of the application name.

# Default time-to-live for cached entries, in seconds.
# VAPI_STORES__TTL=60

# Cache key for the authentication store.
# VAPI_STORES__AUTHENTICATION_CACHE_KEY=auth_cache

# Cache key for the response store.
# VAPI_STORES__RESPONSE_CACHE_KEY=response_cache

# Cache key for the guard session store.
# VAPI_STORES__GUARD_SESSION_KEY=guard_session

# Cache key for the rate limit store.
# VAPI_STORES__RATE_LIMIT_KEY=rate_limit

# Cache key for the user role store.
# VAPI_STORES__USER_ROLE_KEY=user_role

# Cache key for the idempotency store.
# VAPI_STORES__IDEMPOTENCY_KEY=idempotency

# Cache key for provider JWKS documents.
# VAPI_STORES__JWKS_KEY=jwks


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Bind address. Defaults to 0.0.0.0 when running in a container and 127.0.0.1
# otherwise. Use 0.0.0.0 in Docker, 127.0.0.1 for local development.
# VAPI_SERVER__HOST=127.0.0.1

# Port to listen on.
# VAPI_SERVER__PORT=8000

# Scheme used to build the server's public URL.
# VAPI_SERVER__SCHEME=https

# Keep-alive timeout in seconds.
# VAPI_SERVER__KEEP_ALIVE=65

# Reload the server when source files change (development only).
# VAPI_SERVER__RELOAD=false

# Directories watched for changes when reload is enabled. Defaults to the
# application's source directory.
# VAPI_SERVER__RELOAD_DIRS=["src"]

# Maximum request body size in bytes.
# VAPI_SERVER__REQUEST_MAX_BODY_SIZE=5242880


# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# 32-byte hex key used to encrypt rate-limit data in the store. See "Generating
# encryption keys" at the top of this file. (required)
VAPI_RATE_LIMIT__ENCRYPTION_KEY=

# Rate-limit policies. Define one numbered block per policy, starting at 0.
# Each policy supports these fields:
#   NAME             Policy name.
#   CAPACITY         Maximum number of tokens (the burst size).
#   REFILL_RATE      Tokens added per second.
#   SET_HEADERS      Set rate-limit headers on every response.
#   429_SET_HEADERS  Set rate-limit headers on 429 (rate-limited) responses.

# Policy 0
# VAPI_RATE_LIMIT__POLICIES__0__NAME=hourly
# VAPI_RATE_LIMIT__POLICIES__0__CAPACITY=1000
# VAPI_RATE_LIMIT__POLICIES__0__REFILL_RATE=0.27 # 100/hour
# VAPI_RATE_LIMIT__POLICIES__0__SET_HEADERS=true
# VAPI_RATE_LIMIT__POLICIES__0__429_SET_HEADERS=true

# Policy 1
# VAPI_RATE_LIMIT__POLICIES__1__NAME=burst
# VAPI_RATE_LIMIT__POLICIES__1__CAPACITY=30
# VAPI_RATE_LIMIT__POLICIES__1__REFILL_RATE=0.5 # 30/minute
# VAPI_RATE_LIMIT__POLICIES__1__SET_HEADERS=true
# VAPI_RATE_LIMIT__POLICIES__1__429_SET_HEADERS=true


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Enable CORS handling.
# VAPI_CORS__ENABLED=false

# Allowed origins.
# VAPI_CORS__ALLOWED_ORIGINS=["*"]

# Regex matched against the request origin (alternative to ALLOWED_ORIGINS).
# VAPI_CORS__ALLOW_ORIGIN_REGEX=

# HTTP methods allowed in CORS requests.
# VAPI_CORS__ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE"]

# HTTP headers allowed in CORS requests.
# VAPI_CORS__ALLOW_HEADERS=["Content-Type","X-API-KEY"]

# How long (in seconds) browsers may cache the CORS preflight response.
# VAPI_CORS__MAX_AGE=3600


# -----------------------------------------------------------------------------
# Allowed Hosts
# -----------------------------------------------------------------------------

# Enable Host-header validation.
# VAPI_ALLOWED_HOSTS__ENABLED=false

# Allowed host values.
# VAPI_ALLOWED_HOSTS__HOSTS=["*"]


# -----------------------------------------------------------------------------
# OAuth (Discord)
# -----------------------------------------------------------------------------

# Client ID of the Discord OAuth application.
# VAPI_OAUTH__DISCORD_CLIENT_ID=

# Client secret of the Discord OAuth application.
# VAPI_OAUTH__DISCORD_CLIENT_SECRET=

# Callback URL registered with the Discord OAuth application.
# VAPI_OAUTH__DISCORD_CALLBACK_URL=


# -----------------------------------------------------------------------------
# Identity Verification (identify endpoint)
# -----------------------------------------------------------------------------
# Audience allowlists: one entry per client app (iOS bundle ID, OAuth client
# ID). Empty list disables the provider for callers with no self-registered
# audiences. External developers can alternatively register their own audiences
# via PATCH /developers/me with the provider_audiences field (scoped to their
# API key).
# VAPI_OAUTH__APPLE_AUDIENCES='["com.example.iosapp"]'
# VAPI_OAUTH__GOOGLE_AUDIENCES='["1234-abc.apps.googleusercontent.com"]'

# HTTP timeout in seconds for identity provider requests (JWKS, profile APIs).
# VAPI_OAUTH__IDENTITY_HTTP_TIMEOUT=10.0

# How long (in seconds) provider JWKS documents are cached in Redis.
# VAPI_OAUTH__JWKS_CACHE_TTL=21600


# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# These apply only when running the application inside the provided container.

# UID for the application user inside the container.
# PUID=1000

# GID for the application user inside the container.
# PGID=1000

# Run database migrations on startup, before the application loads.
# VAPI_DOCKER_MIGRATE=false

# Seed reference data on startup, before the application loads.
# VAPI_DOCKER_SEED=false

# Username for the API user created on startup.
# VAPI_APIUSER_USERNAME=

# Email for the API user created on startup.
# VAPI_APIUSER_EMAIL=

# Grant the startup API user global-admin privileges.
# VAPI_APIUSER_IS_GLOBAL_ADMIN=false

# Restore the most recent S3 backup on startup, before any migrations or seeds
# run. Requires the AWS settings below. Typically set VAPI_DOCKER_MIGRATE=true
# alongside this so the schema is brought up to date with the current code.
# VAPI_DOCKER_RESTORE=false


# -----------------------------------------------------------------------------
# AWS (S3 / CloudFront)
# -----------------------------------------------------------------------------
# Used for asset storage and database backups (see Database Backups below).

# AWS access key ID. (required)
VAPI_AWS__ACCESS_KEY_ID=

# AWS secret access key. (required)
VAPI_AWS__SECRET_ACCESS_KEY=

# Name of the S3 bucket to use. (required)
VAPI_AWS__S3_BUCKET_NAME=

# Prefix added to all S3 uploads but not included in the URL. (required)
VAPI_AWS__CLOUDFRONT_ORIGIN_PATH=

# CDN URL used to serve uploaded assets (a CNAME is recommended). (required)
VAPI_AWS__CLOUDFRONT_URL=


# -----------------------------------------------------------------------------
# SAQ (Background Workers)
# -----------------------------------------------------------------------------

# Start and stop SAQ worker processes automatically with the application.
# VAPI_SAQ__USE_SERVER_LIFESPAN=true

# Host the worker admin UI at /saq/ when workers start. Requires
# VAPI_SAQ__ADMIN_USERNAME and VAPI_SAQ__ADMIN_PASSWORD to be set.
# VAPI_SAQ__WEB_ENABLED=false

# Number of worker processes to start.
# VAPI_SAQ__PROCESSES=1

# Enable the SAQ plugin.
# VAPI_SAQ__ENABLED=true

# Username for the SAQ web UI (required when VAPI_SAQ__WEB_ENABLED=true).
# VAPI_SAQ__ADMIN_USERNAME=

# Password for the SAQ web UI (required when VAPI_SAQ__WEB_ENABLED=true).
# VAPI_SAQ__ADMIN_PASSWORD=


# -----------------------------------------------------------------------------
# Database Backups
# -----------------------------------------------------------------------------
# Automatic backups upload to S3 and require the AWS settings above.

# Enable scheduled database backups to S3.
# VAPI_BACKUP__ENABLED=false

# Cron schedule for the backup task.
# VAPI_BACKUP__CRON=0 3 * * *

# Number of daily backups to keep.
# VAPI_BACKUP__RETAIN_DAILY=7

# Number of weekly backups to keep (oldest per ISO week).
# VAPI_BACKUP__RETAIN_WEEKLY=4

# Number of monthly backups to keep (oldest per month).
# VAPI_BACKUP__RETAIN_MONTHLY=6

# Number of yearly backups to keep (oldest per year).
# VAPI_BACKUP__RETAIN_YEARLY=2

# -----------------------------------------------------------------------------
# Database Data Retention
# -----------------------------------------------------------------------------
# Retention windows for the scheduled purge task that permanently deletes
# expired data from the database.

# Days to retain archived (soft-deleted) records before permanent deletion.
# Applies to all archivable models and their backing S3 assets.
# VAPI_RETENTION__ARCHIVED_DAYS=30

# Days to retain audit log entries before permanent deletion.
# VAPI_RETENTION__AUDIT_LOG_DAYS=365
